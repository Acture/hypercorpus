---
title: "Figure 1: webwalker — Budgeted Evidence Discovery Pipeline"
---
flowchart LR
    subgraph Inputs
        Q["Query q"]
        G["Linked Corpus G<br/><i>(documents + hyperlinks<br/>with anchor text,<br/>sentence context)</i>"]
    end

    subgraph S1["Stage 1: Dense Seed Retrieval"]
        ST["Sentence-Transformer<br/>topk_similar(q, G, k)"]
    end

    subgraph S2["Stage 2: Hyperlink Walk"]
        direction TB
        WALK["Link-Context Scoring"]
        SC1["Anchor Overlap"]
        SC2["Embedding"]
        SC3["LLM"]
        WALK --- SC1
        WALK --- SC2
        WALK --- SC3
    end

    subgraph S3["Stage 3: Budget Backfill"]
        direction TB
        FILL["budget_fill_relative_drop<br/><i>Fill remaining budget via dense</i>"]
        BAR["🟩 walk | 🟨 backfill<br/><i>Token Budget B</i>"]
        FILL --- BAR
    end

    subgraph Output
        OUT["Selected Evidence S<br/><i>tokens(S) ≤ B</i>"]
    end

    subgraph DS["Downstream (optional)"]
        RAG["RAG / GraphRAG"]
    end

    Q --> ST
    G --> ST
    G -- "graph structure" --> WALK
    ST -- "seeds" --> WALK
    WALK -- "walk nodes" --> FILL
    FILL --> OUT
    OUT -. "compact evidence" .-> RAG

